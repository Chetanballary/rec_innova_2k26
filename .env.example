## API server
# Used by @workspace/api-server (and drizzle config).
# For Supabase, use your Supabase "Connection string" (Session/Transaction pooler).
#
# Example (DO NOT commit real secrets):
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<ref>.supabase.co:5432/postgres?sslmode=require
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.znoqyrmfshzstjejtdom:Culturalcoordinator2k26@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?pgbouncer=true"
sslmode=require
# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.mztfzuyqjxehdcgicpwl:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Optional: per-competition admin credentials JSON
# ADMIN_COMPETITION_CREDENTIALS={"singing":{"username":"singing_admin","password":"..."}}
ADMIN_COMPETITION_CREDENTIALS=

# Optional fallback single-admin creds
ADMIN_USERNAME=admin
ADMIN_PASSWORD=innova2k26

# Optional super-admin creds for cross-competition dashboard access
